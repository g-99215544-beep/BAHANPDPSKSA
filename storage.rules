// ═══════════════════════════════════════════════════════════
// Firebase Storage Security Rules — Portal Bahan Pembelajaran
// ═══════════════════════════════════════════════════════════
//
// Cara guna:
//   1. Buka Firebase Console → Storage → Rules
//   2. Salin dan tampal rules di bawah
//   3. Klik "Publish"
//
// PENTING: Pastikan "Anonymous" sign-in diaktifkan di:
//   Firebase Console → Authentication → Sign-in method → Anonymous → Enable
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Folder utama bahan pembelajaran ────────────────────
    // Struktur: bahan/{subjek}/{kategori}/{tahun}/{topik}/{namaFail}
    match /bahan/{allPaths=**} {

      // BACA: Sesiapa boleh lihat fail (termasuk murid & ibu bapa)
      allow read: if true;

      // TULIS: Hanya pengguna yang log masuk (guru, anonymous Firebase)
      // - Saiz fail: maksimum 50 MB
      // - Jenis fail yang dibenarkan sahaja
      allow write: if request.auth != null
        && request.resource.size <= 50 * 1024 * 1024
        && (
          // Dokumen
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\.wordprocessingml\\.document')
          || request.resource.contentType.matches('application/vnd\\.ms-powerpoint')
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\.presentationml\\.presentation')
          || request.resource.contentType.matches('application/vnd\\.ms-excel')
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet')
          // Gambar
          || request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
          || request.resource.contentType.matches('image/gif')
          || request.resource.contentType.matches('image/webp')
          // Video
          || request.resource.contentType.matches('video/mp4')
          || request.resource.contentType.matches('video/webm')
          || request.resource.contentType.matches('video/quicktime')
          || request.resource.contentType.matches('video/x-msvideo')
        );

      // PADAM: Hanya pengguna yang log masuk boleh padam
      allow delete: if request.auth != null;
    }

    // ── Blok semua akses lain secara lalai ─────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
